# Large datasets (downloaded on demand, cached locally).
# Pattern without a leading slash matches in any directory, so a misconfigured
# HOTPOTQA_DATA_PATH can't accidentally commit the dataset somewhere else.
hotpot_*.json
*.part

# Stray Windows-style absolute paths resolved as relative dirs
[A-Z]:/

