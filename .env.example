# Copy to `.env` and fill in as needed. Every value is optional — the defaults
# below run the notebooks end-to-end with local embeddings on macOS and Windows.
#
# IMPORTANT (cross-platform): do NOT set an absolute HOTPOTQA_DATA_PATH. Leave it
# unset so the path resolves relative to the repo (data/hotpot_train_v1.1.json)
# and the same checkout works on both Mac and PC.

# ---- HotpotQA benchmark ----
HOTPOTQA_SAMPLE_SIZE=25
HOTPOTQA_RANDOM_SEED=42
FORCE_REBUILD_VECTOR_STORE=false
# HOTPOTQA_DATA_PATH=        # leave unset (repo-relative default). Set only to a
#                            # platform-correct absolute path if you must override.

# ---- Embeddings ----
# small | large = Azure / OpenAI-compatible cloud model (preferred when available)
# local         = sentence-transformers model (no API needed)
EMBEDDING_CHOICE=small
EMBEDDING_FALLBACK_TO_LOCAL=true        # auto-fall back to local if cloud is unavailable
LOCAL_EMBEDDING_MODEL=all-mpnet-base-v2

# ---- Cloud provider (only needed for EMBEDDING_CHOICE=small/large) ----
# Standard OpenAI-compatible endpoint:
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Azure OpenAI (set OPENAI_API_VERSION to use the Azure client):
OPENAI_API_VERSION=
# Optional APIM gateway header:
OPENAI_APIM_HEADER_NAME=
OPENAI_APIM_SUBSCRIPTION_KEY=
